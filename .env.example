# Database
DATABASE_URL="postgresql://..."

# Clerk – authentication (dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/
CLERK_WEBHOOK_SECRET=""
# Or use CLERK_WEBHOOK_SIGNING_SECRET from Clerk Dashboard → Webhooks → Signing secret

# Cloudflare R2 – image storage (bucket: car-platform-images, public domain e.g. images.yourdomain.co.uk)
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="car-platform-images"
CLOUDFLARE_R2_PUBLIC_URL="https://images.yourdomain.co.uk"

# Email (Resend)
RESEND_API_KEY=""
FROM_EMAIL="CarDiscovery <noreply@yourdomain.com>"

# App URL (optional, for email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
