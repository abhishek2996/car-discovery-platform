# Database
DATABASE_URL="postgresql://..."

# Auth (NextAuth)
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# UploadThing – required for image uploads (admin model gallery, dealer inventory, etc.)
# Get your token from https://uploadthing.com/dashboard → API Keys → V7
UPLOADTHING_TOKEN=""

# Email (Resend)
RESEND_API_KEY=""
FROM_EMAIL="CarDiscovery <noreply@yourdomain.com>"

# App URL (optional, for email links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
