generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  emailVerified    DateTime?
  name             String?
  image            String?
  phone            String?
  role             UserRole          @default(BUYER)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  password         String?
  accounts         Account[]
  contentAuthored  ContentArticle[]  @relation("ContentAuthor")
  dealer           Dealer?
  leadsAsBuyer     Lead[]            @relation("LeadBuyer")
  reviews          Review[]
  savedComparisons SavedComparison[]
  savedSearches    SavedSearch[]
  sessions         Session[]
  testDriveSlots   TestDriveSlot[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Dealer {
  id             String                @id @default(cuid())
  userId         String                @unique
  name           String
  slug           String                @unique
  city           String
  address        String?
  state          String?
  pincode        String?
  phone          String?
  email          String?
  status         DealerStatus          @default(PENDING)
  logoUrl        String?
  bannerUrl      String?
  description    String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  dealerBrands   DealerBrand[]
  inventoryItems DealerInventoryItem[]
  leads          Lead[]
  reviews        Review[]
  testDriveSlots TestDriveSlot[]
}

model DealerBrand {
  id        String   @id @default(cuid())
  dealerId  String
  brandId   String
  createdAt DateTime @default(now())
  brand     CarBrand @relation(fields: [brandId], references: [id], onDelete: Cascade)
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)

  @@unique([dealerId, brandId])
}

model CarBrand {
  id           String        @id @default(cuid())
  name         String        @unique
  slug         String        @unique
  logoUrl      String?
  country      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  models       CarModel[]
  dealerBrands DealerBrand[]
  upcomingCars UpcomingCar[]
}

model CarModel {
  id           String        @id @default(cuid())
  brandId      String
  name         String
  slug         String
  bodyType     BodyType?
  segment      String?
  minPrice     Decimal?      @db.Decimal(12, 2)
  maxPrice     Decimal?      @db.Decimal(12, 2)
  imageUrl     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  brand        CarBrand      @relation(fields: [brandId], references: [id], onDelete: Cascade)
  variants     CarVariant[]
  leads        Lead[]        @relation("LeadCarModel")
  upcomingCars UpcomingCar[]

  @@unique([brandId, slug])
}

model CarVariant {
  id              String                @id @default(cuid())
  modelId         String
  name            String
  slug            String
  fuelType        FuelType?
  transmission    TransmissionType?
  engine          String?
  power           String?
  torque          String?
  mileage         String?
  seating         Int?
  length          Int?
  width           Int?
  height          Int?
  wheelbase       Int?
  bootCapacity    Int?
  fuelTank        Int?
  exShowroomPrice Decimal?              @db.Decimal(12, 2)
  imageUrl        String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  model           CarModel              @relation(fields: [modelId], references: [id], onDelete: Cascade)
  inventory       DealerInventoryItem[]
  leads           Lead[]                @relation("LeadCarVariant")
  reviews         Review[]
  testDriveSlots  TestDriveSlot[]

  @@unique([modelId, slug])
}

model DealerInventoryItem {
  id           String              @id @default(cuid())
  dealerId     String
  variantId    String
  onRoadPrice  Decimal?            @db.Decimal(12, 2)
  stockStatus  String?
  offers       String?
  visibility   InventoryVisibility @default(VISIBLE)
  colorOptions String?
  imageUrls    String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  dealer       Dealer              @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  variant      CarVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([dealerId, variantId])
}

model Lead {
  id           String      @id @default(cuid())
  buyerId      String
  dealerId     String
  type         LeadType
  status       LeadStatus  @default(NEW)
  source       String?
  carModelId   String?
  carVariantId String?
  message      String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  buyer        User        @relation("LeadBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  carModel     CarModel?   @relation("LeadCarModel", fields: [carModelId], references: [id])
  carVariant   CarVariant? @relation("LeadCarVariant", fields: [carVariantId], references: [id])
  dealer       Dealer      @relation(fields: [dealerId], references: [id], onDelete: Cascade)
}

model TestDriveSlot {
  id        String              @id @default(cuid())
  dealerId  String
  variantId String
  buyerId   String
  slotAt    DateTime
  status    TestDriveSlotStatus @default(REQUESTED)
  notes     String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt
  buyer     User                @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  dealer    Dealer              @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  variant   CarVariant          @relation(fields: [variantId], references: [id], onDelete: Cascade)
}

model Review {
  id           String      @id @default(cuid())
  type         ReviewType
  rating       Int
  title        String?
  content      String?
  carVariantId String?
  dealerId     String?
  authorId     String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  author       User?       @relation(fields: [authorId], references: [id])
  carVariant   CarVariant? @relation(fields: [carVariantId], references: [id])
  dealer       Dealer?     @relation(fields: [dealerId], references: [id])
}

model UpcomingCar {
  id             String    @id @default(cuid())
  brandId        String
  modelId        String?
  name           String
  expectedLaunch String?
  estimatedPrice String?
  keyHighlights  String?
  imageUrl       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  brand          CarBrand  @relation(fields: [brandId], references: [id], onDelete: Cascade)
  model          CarModel? @relation(fields: [modelId], references: [id])
}

model ContentArticle {
  id           String             @id @default(cuid())
  type         ContentArticleType
  title        String
  slug         String             @unique
  body         String?
  heroMediaUrl String?
  tags         String?
  authorId     String?
  publishedAt  DateTime?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  author       User?              @relation("ContentAuthor", fields: [authorId], references: [id])
}

model HeroSlide {
  id            String   @id @default(cuid())
  title         String
  subtitle      String?
  benefitText   String?
  dealerName    String?
  locationsJson String?
  imageUrl      String?
  sortOrder     Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String?
  filters   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SavedComparison {
  id         String   @id @default(cuid())
  userId     String
  name       String?
  variantIds String
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum UserRole {
  BUYER
  DEALER
  ADMIN
}

enum DealerStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum LeadType {
  ENQUIRY
  TEST_DRIVE
}

enum LeadStatus {
  NEW
  CONTACTED
  IN_PROGRESS
  COMPLETED
  DROPPED
}

enum TestDriveSlotStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum ReviewType {
  EXPERT
  USER
}

enum BodyType {
  HATCHBACK
  SEDAN
  SUV
  MUV
  // COUPÉ
  CONVERTIBLE
  WAGON
  PICKUP
  LUXURY
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
  PLUGIN_HYBRID
}

enum TransmissionType {
  MANUAL
  AUTOMATIC
  AMT
  CVT
  DCT
  SINGLE_SPEED
  DUAL_CLUTCH
}

enum ContentArticleType {
  NEWS
  EXPERT_REVIEW
  FEATURE
  COMPARISON
}

enum InventoryVisibility {
  DRAFT
  VISIBLE
  HIDDEN
}
